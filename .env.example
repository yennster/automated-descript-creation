# Required: get from Descript Settings → API tokens
DESCRIPT_API_TOKEN=

# Optional: only used by /v1/status sanity checks; the import endpoint
# infers the drive from the token.
DESCRIPT_DRIVE_ID=

# Optional: enables AI-generated narration + richer slide outlines.
# Without it, transcript.md gets [Write narration for ...] placeholders
# and mode 2c uses a heuristic to split your --describe into slides.
# Note: a Claude Max subscription does NOT include API access — get a key
# at https://console.anthropic.com if you want this.
ANTHROPIC_API_KEY=
