# Required: get from Descript Settings → API tokens
DESCRIPT_API_TOKEN=

# Optional: only used by /v1/status sanity checks; the import endpoint
# infers the drive from the token.
DESCRIPT_DRIVE_ID=

# AI uses the `gemini` CLI directly — no API key here. Install it via
# `npm i -g @google/gemini-cli` and `gemini` (interactive once to authenticate).
