{
  "name": "automated-descript-creation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Automate demo videos for AI-built apps via Descript: capture, script, draft.",
  "bin": {
    "adc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "capture": "tsx src/cli.ts capture",
    "stitch": "tsx src/cli.ts stitch",
    "mock": "tsx src/cli.ts mock",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.48.0",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
